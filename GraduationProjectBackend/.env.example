# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Database (PostgreSQL)
# REQUIRED: replace USER and PASSWORD
DATABASE_URL="postgresql://abdo:abdo@localhost:5432/graduation_db?schema=public"

# JWT
# REQUIRED: put a strong secret
JWT_SECRET="change-me"
JWT_EXPIRES_IN="1d"
JWT_REMEMBER_EXPIRES_IN="30d"

# SMTP (Email Verification)
# OPTIONAL in dev if you disable sending in code
# For Gmail you must use App Password (16 chars), NOT your real password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER="your.sender@gmail.com"
SMTP_PASS="your_app_password_here"
MAIL_FROM="Graduation Project <your.sender@gmail.com>"

# Verification
VERIFICATION_CODE_TTL_MIN=10
PASSWORD_RESET_TTL_MIN=10
FRONTEND_URL=http://localhost:3000

# GitHub App + Integration
GITHUB_APP_ID=
GITHUB_APP_NAME=
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_APP_CLIENT_ID=Iv23lihJCHtH1Asa16JX
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_WEBHOOK_SECRET=
GITHUB_APP_INSTALL_URL=
GITHUB_APP_SETUP_CALLBACK_URL=http://localhost:4000/api/v1/github/install/callback
GITHUB_INTEGRATION_REDIRECT_URI=http://localhost:4000/api/v1/github/user/callback
GITHUB_TOKEN_ENCRYPTION_SECRET=change-me

# Upload limits (MB). Set to 0 for unlimited.
DOCUMENT_MAX_SIZE_MB=0
RESOURCE_MAX_SIZE_MB=0
