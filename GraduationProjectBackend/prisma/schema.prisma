  status         WeeklyReportStatus @default(DRAFT)
  reviewComment  String?
  isSubmitted    Boolean            @default(false)
  submittedAt    DateTime?
  reviewedAt     DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  team        Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  submittedBy User? @relation("WeeklyReportSubmitter", fields: [submittedById], references: [id], onDelete: SetNull)
  reviewedBy  User? @relation("WeeklyReportReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@unique([teamId, weekLabel])
  @@index([teamId, createdAt])
  @@index([teamId, status])
  @@index([submittedById])
  @@index([reviewedById])
}

model Submission {
  id                String               @id @default(cuid())
  teamId            String
  deliverableType   DeliverableType
  sdlcPhase         TeamStage
  sourceType        SubmissionSourceType @default(MANUAL_UPLOAD)
  title             String?
  notes             String?
  status            SubmissionStatus     @default(PENDING)
  fileName          String?
  fileSize          Int?
  fileType          String?
  fileUrl           String?
  githubReleaseId   String?              @unique
  githubReleaseTag  String?
  githubReleaseUrl  String?
  artifactUrl       String?
  version           Int                  @default(1)
  submittedByUserId String?

  // Two-step review flow:
  // Step 1 — TA first-pass review (recommendation)
  taRecommendedGrade Int?
  taFeedback         String?
  taReviewedByUserId String?
  taReviewedAt       DateTime?

  // Step 2 — Doctor final grade (authoritative)
  reviewedByUserId String?
  reviewedAt       DateTime?
  feedback         String?
  grade            Int?

  // Rubric used for grading: [{ name, score, maxScore }]
  rubric Json?

  // Grade revision audit trail (every time the doctor changes the grade
  // after the first finalize, the previous state is pushed here).
  // Stored as an array of { grade, feedback, rubric, reviewedAt, reviewedBy, changedAt, reason }.
  gradeHistory Json?

  // Defense meeting link (only required for DEPLOYMENT-phase deliverables).
  defenseMeetingId String? @unique

  submittedAt DateTime  @default(now())
  deadline    DateTime?
  late        Boolean   @default(false)

  // Duplicate detection (gamification anti-cheat)
  fileHash           String?
  normalizedTextHash String?
  contentFingerprint String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team           Team                @relation(fields: [teamId], references: [id], onDelete: Cascade)
  submittedBy    User?               @relation("SubmissionSubmitter", fields: [submittedByUserId], references: [id], onDelete: SetNull)
  reviewedBy     User?               @relation("SubmissionReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  taReviewedBy   User?               @relation("SubmissionTAReviewer", fields: [taReviewedByUserId], references: [id], onDelete: SetNull)
  defenseMeeting Meeting?            @relation("MeetingForSubmission", fields: [defenseMeetingId], references: [id], onDelete: SetNull)
  comments       SubmissionComment[]

  @@index([teamId, deliverableType])
  @@index([teamId, sdlcPhase])
  @@index([teamId, status])
  @@index([submittedByUserId])
  @@index([reviewedByUserId])
  @@index([taReviewedByUserId])
  @@index([fileHash])
  @@index([normalizedTextHash])
  @@index([teamId, deliverableType, version])
}

// Conversation thread on a single submission.
