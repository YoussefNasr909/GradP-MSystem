datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  STUDENT
  LEADER
  TA
  DOCTOR
  SUPPORT
  ADMIN
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum ProfileVisibility {
  PUBLIC
  TEAM_ONLY
  PRIVATE
}

enum TeamVisibility {
  PUBLIC
  PRIVATE
}

enum TeamStage {
  REQUIREMENTS
  DESIGN
  IMPLEMENTATION
  TESTING
  DEPLOYMENT
  MAINTENANCE
}

enum TeamInvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

enum TeamJoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum SupervisorRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
}

enum GitHubOwnerType {
  USER
  ORGANIZATION
}

enum GitHubRepositoryVisibility {
  PUBLIC
  PRIVATE
  INTERNAL
}

enum GitHubRepositoryConnectionStatus {
  PENDING
  ACTIVE
  ERROR
  DISCONNECTED
}

enum GitHubSyncStatus {
  IDLE
  SYNCING
  DEGRADED
  ERROR
}

enum GitHubWebhookDeliveryStatus {
  PENDING
  PROCESSED
  FAILED
  IGNORED
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  REVIEW
  APPROVED
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskType {
  CODE
  DOCUMENTATION
  DESIGN
  RESEARCH
  MEETING
  PRESENTATION
  OTHER
}

enum TaskIntegrationMode {
  MANUAL
  GITHUB
}

enum TaskOrigin {
  GPMS
  GITHUB_IMPORT
}

enum TaskReviewDecision {
  APPROVED
  CHANGES_REQUESTED
}

enum TaskReviewerRole {
  LEADER
  TA
  ADMIN
}

enum TaskSubmissionEvidenceType {
  FILE
  LINK
}

enum SprintStatus {
  PLANNED
  ACTIVE
  COMPLETED
}

enum WeeklyReportStatus {
  DRAFT
  SUBMITTED
  APPROVED
  CHANGES_REQUESTED
}

enum SprintEvaluationStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  NEEDS_CHANGES
}

enum SprintEvaluationEvaluatorRole {
  TA
  DOCTOR
}

enum DeliverableType {
  SRS
  UML
  PROTOTYPE
  CODE
  TEST_PLAN
  FINAL_REPORT
  PRESENTATION
}

enum SubmissionSourceType {
  MANUAL_UPLOAD
  GITHUB_RELEASE
  GITHUB_ARTIFACT
}

enum SubmissionStatus {
  PENDING
  UNDER_REVIEW
  REVISION_REQUIRED
  APPROVED
}

enum ProposalStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  REVISION_REQUESTED
  APPROVED
  REJECTED
}

enum DocumentCategory {
  DELIVERABLE
  DOCUMENTATION
  OTHER
}

enum ResourceCategory {
  DOCUMENTATION
  TUTORIAL
  CODE
  TEMPLATE
  OTHER
}

enum ResourceType {
  FILE
  VIDEO
  LINK
  GITHUB
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_REVIEWED
  TASK_APPROVED
  TASK_CHANGES_REQUESTED
  TEAM_INVITE_RECEIVED
  TEAM_JOIN_REQUEST_RECEIVED
  TEAM_JOIN_REQUEST_APPROVED
  TEAM_JOIN_REQUEST_REJECTED
  SUPERVISOR_REQUEST_RECEIVED
  SUPERVISOR_REQUEST_ACCEPTED
  SUPERVISOR_REQUEST_DECLINED
  SUBMISSION_GRADED
  SUBMISSION_FEEDBACK
  SYSTEM
  // Gamification
  XP_AWARDED
  XP_FROZEN
  XP_REVERSED
  BADGE_UNLOCKED
  XP_ADJUSTMENT_REVIEWED
  SUPPORT_TICKET_CREATED
  SUPPORT_TICKET_REPLY
  SUPPORT_TICKET_STATUS_CHANGED
  SUPPORT_TICKET_ASSIGNED
}

enum SupportTicketSource {
  FORM
  CHAT
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_ON_USER
  RESOLVED
  CLOSED
}

enum SupportTicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum SupportTicketCategory {
  BUG
  FEATURE
  QUESTION
  ACCOUNT
  TECHNICAL
  GENERAL
}

enum SupportTicketMessageVisibility {
  PUBLIC
  INTERNAL
}

enum SupportTicketActivityType {
  CREATED
  MESSAGE_ADDED
  INTERNAL_NOTE_ADDED
  STATUS_CHANGED
  PRIORITY_CHANGED
  CATEGORY_CHANGED
  ASSIGNED
  REOPENED
}

enum DiscussionCategory {
  TECHNICAL
  TEAM
  RESOURCES
  GENERAL
}

enum RiskStatus {
  OPEN
  MONITORING
  RESOLVED
}

enum RiskApprovalStatus {
  PENDING
  APPROVED
  REVISION_REQUESTED
}

enum RiskChance {
  LOW
  MEDIUM
  HIGH
}

enum RiskSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum CalendarProvider {
  GOOGLE
  OUTLOOK
}

enum MeetingStatus {
  PENDING_APPROVAL
  CONFIRMED
  DECLINED
  CANCELLED
  COMPLETED
}

enum MeetingMode {
  VIRTUAL
  IN_PERSON
  HYBRID
}

enum MeetingProvider {
  GOOGLE_MEET
  MICROSOFT_TEAMS
  MANUAL
}

enum MeetingParticipantRole {
  ORGANIZER
  LEADER
  DOCTOR
  TA
  MEMBER
  EXTERNAL
}

enum MeetingResponseStatus {
  PENDING
  ACCEPTED
  DECLINED
  TENTATIVE
}

enum MeetingApprovalStatus {
  PENDING
  APPROVED
  DECLINED
  PROPOSED_NEW_TIME
}

enum ExternalSyncStatus {
  NOT_CONNECTED
  PENDING
  SYNCED
  ERROR
  DISCONNECTED
}

enum Department {
  COMPUTER_SCIENCE
  SOFTWARE_ENGINEERING
  INFORMATION_TECHNOLOGY
  COMPUTER_ENGINEERING
  DATA_SCIENCE
  ARTIFICIAL_INTELLIGENCE
  CYBERSECURITY_INFOSEC
  INFORMATION_SYSTEMS
  BIOINFORMATICS
}

enum AcademicYear {
  YEAR_1
  YEAR_2
  YEAR_3
  YEAR_4
  YEAR_5
}

enum PreferredTrack {
  FRONTEND_DEVELOPMENT
  BACKEND_DEVELOPMENT
  FULLSTACK_DEVELOPMENT
  MOBILE_APP_DEVELOPMENT
  DEVOPS
  CLOUD_ENGINEERING
  SOFTWARE_ARCHITECTURE
  QUALITY_ASSURANCE
  GAME_DEVELOPMENT
}

model User {
  id String @id @default(cuid())

  firstName String
  lastName  String
  email     String  @unique
  phone     String?

  academicId     String          @unique
  department     Department?
  academicYear   AcademicYear?
  preferredTrack PreferredTrack?

  // OAuth
  googleId       String? @unique
  githubId       String? @unique
  avatarUrl      String?
  bio            String?
  linkedinUrl    String?
  githubUsername String?

  // Auth (local)
  passwordHash String?

  role          Role          @default(STUDENT)
  accountStatus AccountStatus @default(ACTIVE)

  // Email verification
  isEmailVerified            Boolean   @default(false)
  emailVerificationCodeHash  String?
  emailVerificationExpiresAt DateTime?

  // Password reset
  passwordResetCodeHash  String?
  passwordResetExpiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ledTeam                      Team?                              @relation("TeamLeader")
  doctorTeams                  Team[]                             @relation("TeamDoctor")
  taTeams                      Team[]                             @relation("TeamTA")
  teamMembership               TeamMember?                        @relation("TeamMemberUser")
  sentTeamInvitations          TeamInvitation[]                   @relation("TeamInvitationSender")
  receivedTeamInvitations      TeamInvitation[]                   @relation("TeamInvitationRecipient")
  teamJoinRequests             TeamJoinRequest[]                  @relation("TeamJoinRequestUser")
  sentSupervisorRequests       TeamSupervisorRequest[]            @relation("TeamSupervisorRequestSender")
  receivedSupervisorRequests   TeamSupervisorRequest[]            @relation("TeamSupervisorRequestRecipient")
  githubConnection             GitHubUserConnection?
  assignedTasks                Task[]                             @relation("TaskAssignee")
  createdTasks                 Task[]                             @relation("TaskCreator")
  reviewedTasks                Task[]                             @relation("TaskReviewer")
  authoredTaskReviews          TaskReview[]                       @relation("TaskReviewAuthor")
  uploadedTaskEvidence         TaskSubmissionEvidence[]           @relation("TaskEvidenceUploader")
  createdSprints               Sprint[]                           @relation("SprintCreator")
  authoredSprintEvaluations    SprintEvaluation[]                 @relation("SprintEvaluationEvaluator")
  reviewedSprintEvaluations    SprintEvaluation[]                 @relation("SprintEvaluationReviewer")
  submittedWeeklyReports       WeeklyReport[]                     @relation("WeeklyReportSubmitter")
  reviewedWeeklyReports        WeeklyReport[]                     @relation("WeeklyReportReviewer")
  submittedSubmissions         Submission[]                       @relation("SubmissionSubmitter")
  reviewedSubmissions          Submission[]                       @relation("SubmissionReviewer")
  taReviewedSubmissions        Submission[]                       @relation("SubmissionTAReviewer")
  authoredProposals            Proposal[]                         @relation("ProposalAuthor")
  reviewedProposals            Proposal[]                         @relation("ProposalReviewer")
  authoredSupervisorNotes      TeamSupervisorNote[]               @relation("SupervisorNoteAuthor")
  setDeliverableDeadlines      TeamDeliverableDeadline[]          @relation("DeadlineSetter")
  authoredAnnouncements        Announcement[]                     @relation("AnnouncementAuthor")
  authoredSubmissionComments   SubmissionComment[]                @relation("SubmissionCommentAuthor")
  createdRubricTemplates       TeamRubricTemplate[]               @relation("RubricTemplateCreator")
  uploadedDocuments            TeamDocument[]                     @relation("DocumentUploader")
  createdResources             TeamResource[]                     @relation("ResourceCreator")
  createdRisks                 Risk[]                             @relation("RiskCreator")
  monitoredRisks               Risk[]                             @relation("RiskMonitor")
  approvedRisks                Risk[]                             @relation("RiskApprover")
  notifications                Notification[]                     @relation("UserNotifications")
  supportTicketsRequested      SupportTicket[]                    @relation("SupportTicketRequester")
  supportTicketsAssigned       SupportTicket[]                    @relation("SupportTicketAssignee")
  authoredSupportMessages      SupportTicketMessage[]             @relation("SupportTicketMessageAuthor")
  uploadedSupportAttachments   SupportTicketAttachment[]          @relation("SupportTicketAttachmentUploader")
  supportTicketActivities      SupportTicketActivity[]            @relation("SupportTicketActivityActor")
  supportSavedRepliesCreated   SupportSavedReply[]                @relation("SupportSavedReplyCreator")
  settings                     UserSettings?
  organizedMeetings            Meeting[]                          @relation("MeetingOrganizer")
  meetingParticipants          MeetingParticipant[]               @relation("MeetingParticipantUser")
  meetingApprovals             MeetingApproval[]                  @relation("MeetingApprovalUser")
  calendarIntegrations         CalendarIntegration[]
  teamGroupChatParticipants    TeamGroupConversationParticipant[]
  sentTeamGroupMessages        TeamGroupMessage[]                 @relation("TeamGroupMessageSender")
  directChatConversationsOne   DirectChatConversation[]           @relation("DirectChatConversationUserOne")
  directChatConversationsTwo   DirectChatConversation[]           @relation("DirectChatConversationUserTwo")
  sentDirectChatMessages       DirectChatMessage[]                @relation("DirectChatMessageSender")
  receivedDirectChatMessages   DirectChatMessage[]                @relation("DirectChatMessageRecipient")
  deletedDirectChatMessages    DirectChatMessage[]                @relation("DirectChatMessageDeletedBy")
  discussionPosts              Discussion[]                       @relation("DiscussionAuthor")
  discussionComments           DiscussionComment[]                @relation("DiscussionCommentAuthor")
  discussionLikes              DiscussionLike[]                   @relation("DiscussionLikeUser")
  discussionViews              DiscussionView[]                   @relation("DiscussionViewUser")
  // Gamification relations
  createdGamificationRules     GamificationRule[]                 @relation("GamificationRuleCreator")
  gamificationEventsAsActor    GamificationEvent[]                @relation("GamificationEventActor")
  xpTransactionsAsRecipient    XpTransaction[]                    @relation("XpTransactionRecipientUser")
  xpTransactionsCreated        XpTransaction[]                    @relation("XpTransactionCreator")
  xpTransactionsReviewed       XpTransaction[]                    @relation("XpTransactionReviewer")
  xpBalance                    UserXpBalance?
  userBadges                   UserBadge[]                        @relation("UserBadgeOwner")
  leaderboardSnapshots         LeaderboardSnapshot[]              @relation("LeaderboardSnapshotUser")
  githubContributions          GitHubContribution[]               @relation("GitHubContributionUser")
  suspiciousActivityCases      SuspiciousActivityCase[]           @relation("SuspiciousActivityUser")
  assignedSuspiciousCases      SuspiciousActivityCase[]           @relation("SuspiciousActivityReviewer")
  xpAdjustmentRequestsCreated  XpAdjustmentRequest[]              @relation("XpAdjustmentRequester")
  xpAdjustmentRequestsAsTarget XpAdjustmentRequest[]              @relation("XpAdjustmentTargetUser")
  xpAdjustmentRequestsApproved XpAdjustmentRequest[]              @relation("XpAdjustmentApprover")
  gamificationAuditLogs        GamificationAuditLog[]             @relation("GamificationAuditActor")
  coinBalance                  UserCoinBalance?                   @relation("UserCoinBalanceOwner")
  coinTransactions             CoinTransaction[]                  @relation("CoinTransactionUser")
  questProgress                UserQuestProgress[]                @relation("UserQuestProgressOwner")
  rewardPurchases              RewardPurchase[]                   @relation("RewardPurchaseUser")
}

model UserSettings {
  id     String @id @default(cuid())
  userId String @unique

  emailNotifications   Boolean @default(true)
  websiteNotifications Boolean @default(true)
  soundNotifications   Boolean @default(true)
  taskReminders        Boolean @default(true)
  meetingReminders     Boolean @default(true)
  submissionAlerts     Boolean @default(true)
  teamUpdates          Boolean @default(true)
  mentionNotifications Boolean @default(true)
  deadlineWarnings     Boolean @default(true)
  gradeNotifications   Boolean @default(true)
  weeklyDigest         Boolean @default(false)

  theme            String  @default("system")
  fontSize         Int     @default(16)
  compactMode      Boolean @default(false)
  reducedMotion    Boolean @default(false)
  highContrast     Boolean @default(false)
  sidebarCollapsed Boolean @default(false)

  profileVisibility ProfileVisibility @default(PUBLIC)
  showEmail         Boolean           @default(true)
  showActivity      Boolean           @default(true)
  showTeam          Boolean           @default(true)
  showOnlineStatus  Boolean           @default(true)

  loginAlerts                     Boolean  @default(true)
  sessionTimeout                  Int      @default(30)
  twoFactorEnabled                Boolean  @default(false)
  twoFactorSecretEncrypted        String?
  pendingTwoFactorSecretEncrypted String?
  recoveryCodeHashes              String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([profileVisibility])
}

model Team {
  id                String         @id @default(cuid())
  name              String
  bio               String
  leaderId          String         @unique
  doctorId          String?
  taId              String?
  inviteCode        String         @unique
  maxMembers        Int            @default(5)
  visibility        TeamVisibility @default(PUBLIC)
  allowJoinRequests Boolean        @default(true)
  stage             TeamStage      @default(REQUIREMENTS)
  stack             String[]       @default([])
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  leader                    User                      @relation("TeamLeader", fields: [leaderId], references: [id], onDelete: Cascade)
  doctor                    User?                     @relation("TeamDoctor", fields: [doctorId], references: [id], onDelete: SetNull)
  ta                        User?                     @relation("TeamTA", fields: [taId], references: [id], onDelete: SetNull)
  members                   TeamMember[]
  invitations               TeamInvitation[]
  joinRequests              TeamJoinRequest[]
  supervisorRequests        TeamSupervisorRequest[]
  githubRepository          GitHubTeamRepository?
  tasks                     Task[]
  taskSubmissionEvidence    TaskSubmissionEvidence[]
  sprints                   Sprint[]
  weeklyReports             WeeklyReport[]
  submissions               Submission[]
  documents                 TeamDocument[]
  meetings                  Meeting[]
  risks                     Risk[]
  proposal                  Proposal?
  supervisorNotes           TeamSupervisorNote[]
  deliverableDeadlines      TeamDeliverableDeadline[]
  announcements             Announcement[]
  announcementTargets       AnnouncementTargetTeam[]
  rubricTemplates           TeamRubricTemplate[]
  groupConversation         TeamGroupConversation?
  // Gamification relations
  gamificationEvents        GamificationEvent[]       @relation("GamificationEventTeam")
  xpTransactionsAsRecipient XpTransaction[]           @relation("XpTransactionRecipientTeam")
  xpBalance                 TeamXpBalance?
  teamBadges                TeamBadge[]               @relation("TeamBadgeOwner")
  leaderboardSnapshots      LeaderboardSnapshot[]     @relation("LeaderboardSnapshotTeam")
  githubContributions       GitHubContribution[]      @relation("GitHubContributionTeam")
  suspiciousActivityCases   SuspiciousActivityCase[]  @relation("SuspiciousActivityTeam")
  xpAdjustmentRequests      XpAdjustmentRequest[]     @relation("XpAdjustmentTargetTeam")

  @@index([visibility, stage])
  @@index([name])
  @@index([doctorId])
  @@index([taId])
}

model Risk {
  id               String             @id @default(cuid())
  teamId           String
  title            String
  description      String
  category         String
  chance           RiskChance         @default(MEDIUM)
  impact           RiskChance         @default(MEDIUM)
  severity         RiskSeverity?
  status           RiskStatus         @default(OPEN)
  approvalStatus   RiskApprovalStatus @default(PENDING)
  mitigation       String?
  monitoringNotes  String?
  resolutionNotes  String?
  approvalNote     String?
  createdByUserId  String
  monitorUserId    String?
  approvedByUserId String?
  approvedAt       DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  team       Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdBy  User  @relation("RiskCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  monitor    User? @relation("RiskMonitor", fields: [monitorUserId], references: [id], onDelete: SetNull)
  approvedBy User? @relation("RiskApprover", fields: [approvedByUserId], references: [id], onDelete: SetNull)

  @@index([teamId, status])
  @@index([teamId, approvalStatus])
  @@index([monitorUserId])
  @@index([approvedByUserId])
}

model TeamMember {
  id       String   @id @default(cuid())
  teamId   String
  userId   String   @unique
  joinedAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation("TeamMemberUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([teamId])
}

model TeamInvitation {
  id            String               @id @default(cuid())
  teamId        String
  invitedUserId String
  invitedById   String
  status        TeamInvitationStatus @default(PENDING)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  team        Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  invitedUser User @relation("TeamInvitationRecipient", fields: [invitedUserId], references: [id], onDelete: Cascade)
  invitedBy   User @relation("TeamInvitationSender", fields: [invitedById], references: [id], onDelete: Cascade)

  @@unique([teamId, invitedUserId])
  @@index([invitedUserId, status])
}

model TeamJoinRequest {
  id        String                @id @default(cuid())
  teamId    String
  userId    String
  message   String?
  status    TeamJoinRequestStatus @default(PENDING)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation("TeamJoinRequestUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId, status])
}

model TeamSupervisorRequest {
  id                 String                  @id @default(cuid())
  teamId             String
  supervisorId       String
  requestedById      String
  supervisorRole     Role
  projectName        String
  projectDescription String
  technologies       String[]                @default([])
  status             SupervisorRequestStatus @default(PENDING)
  respondedAt        DateTime?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  team        Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  supervisor  User @relation("TeamSupervisorRequestRecipient", fields: [supervisorId], references: [id], onDelete: Cascade)
  requestedBy User @relation("TeamSupervisorRequestSender", fields: [requestedById], references: [id], onDelete: Cascade)

  @@unique([teamId, supervisorId])
  @@index([teamId, status])
  @@index([supervisorId, status])
  @@index([supervisorRole, status])
}

model GitHubTeamRepository {
  id                          String                           @id @default(cuid())
  teamId                      String                           @unique
  ownerLogin                  String
  ownerType                   GitHubOwnerType                  @default(USER)
  repoName                    String
  fullName                    String                           @unique
  installationId              String?
  defaultBranch               String                           @default("main")
  visibility                  GitHubRepositoryVisibility       @default(PRIVATE)
  repoUrl                     String
  cloneUrlHttps               String?
  cloneUrlSsh                 String?
  connectionStatus            GitHubRepositoryConnectionStatus @default(PENDING)
  syncStatus                  GitHubSyncStatus                 @default(IDLE)
  lastSyncAt                  DateTime?
  lastWebhookAt               DateTime?
  syncIssuesToTasks           Boolean                          @default(true)
  syncActivityToWeeklyReports Boolean                          @default(true)
  syncReleasesToSubmissions   Boolean                          @default(true)
  createdAt                   DateTime                         @default(now())
  updatedAt                   DateTime                         @updatedAt

  team              Team                    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  webhookDeliveries GitHubWebhookDelivery[]
  syncCursors       GitHubSyncCursor[]
  contributions     GitHubContribution[]

  @@index([ownerLogin, repoName])
  @@index([installationId])
}

model GitHubUserConnection {
  id                    String    @id @default(cuid())
  userId                String    @unique
  githubUserId          String    @unique
  login                 String
  displayName           String?
  avatarUrl             String?
  accessTokenEncrypted  String
  refreshTokenEncrypted String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  tokenType             String?
  scopes                String[]  @default([])
  isActive              Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GitHubWebhookDelivery {
  id                String                      @id @default(cuid())
  repositoryId      String?
  deliveryId        String                      @unique
  event             String
  action            String?
  signatureVerified Boolean                     @default(false)
  status            GitHubWebhookDeliveryStatus @default(PENDING)
  error             String?
  payload           Json?
  processedAt       DateTime?
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt

  repository GitHubTeamRepository? @relation(fields: [repositoryId], references: [id], onDelete: SetNull)

  @@index([repositoryId, event])
  @@index([status, createdAt])
}

model GitHubSyncCursor {
  id           String    @id @default(cuid())
  repositoryId String
  resourceType String
  cursorKey    String?
  etag         String?
  cursor       Json?
  lastSyncedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  repository GitHubTeamRepository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@unique([repositoryId, resourceType])
}

model Task {
  id                        String              @id @default(cuid())
  teamId                    String
  sprintId                  String?
  taskType                  TaskType            @default(OTHER)
  integrationMode           TaskIntegrationMode @default(MANUAL)
  origin                    TaskOrigin          @default(GPMS)
  githubIssueId             String?             @unique
  githubIssueNumber         Int?
  githubIssueUrl            String?
  githubIssueState          String?
  githubBranchName          String?
  githubPullRequestId       String?
  githubPullRequestNumber   Int?
  githubPullRequestUrl      String?
  githubPullRequestState    String?
  githubPullRequestBase     String?
  githubPullRequestHead     String?
  githubPullRequestMergedAt DateTime?
  githubLatestCommitSha     String?
  githubLatestCommitUrl     String?
  githubCommitCount         Int                 @default(0)
  title                     String
  description               String?
  status                    TaskStatus          @default(BACKLOG)
  priority                  TaskPriority        @default(MEDIUM)
  storyPoints               Int                 @default(3)
  actualPoints              Int?
  unplanned                 Boolean             @default(false)
  assigneeUserId            String?
  createdByUserId           String?
  reviewedByUserId          String?
  labels                    String[]            @default([])
  startDate                 DateTime?
  dueDate                   DateTime?
  acceptedAt                DateTime?
  submittedForReviewAt      DateTime?
  reviewedAt                DateTime?
  reviewFeedback            String?
  reviewComment             String?
  reviewDecision            TaskReviewDecision?
  reviewSnapshot            Json?
  syncedFromGithub          Boolean             @default(false)
  lastSyncedAt              DateTime?
  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime            @updatedAt

  team                Team                     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  sprint              Sprint?                  @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  assignee            User?                    @relation("TaskAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  createdBy           User?                    @relation("TaskCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  reviewedBy          User?                    @relation("TaskReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  githubContributions GitHubContribution[]     @relation("GitHubContributionTask")
  submissionEvidence  TaskSubmissionEvidence[]
  reviews             TaskReview[]

  @@unique([teamId, githubIssueNumber])
  @@index([teamId, status])
  @@index([teamId, sprintId])
  @@index([sprintId, status])
  @@index([assigneeUserId])
  @@index([createdByUserId])
  @@index([reviewedByUserId])
  @@index([teamId, integrationMode])
  @@index([teamId, githubPullRequestNumber])
}

/// One row per review action on a Task. Both the team leader and the team TA
/// can leave a review on the same task, and either one's APPROVED moves the
/// task forward (whichever lands first). The other party can still record a
/// supplementary review afterward — that just appends another row without
/// changing the task status. We keep the pointer fields on Task too (latest
/// decisive review) so existing reads don't break.
model TaskReview {
  id             String             @id @default(cuid())
  taskId         String
  reviewerUserId String
  reviewerRole   TaskReviewerRole
  decision       TaskReviewDecision
  comment        String?
  snapshot       Json?
  createdAt      DateTime           @default(now())

  task     Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  reviewer User @relation("TaskReviewAuthor", fields: [reviewerUserId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
  @@index([reviewerUserId])
}

model TaskSubmissionEvidence {
  id               String                     @id @default(cuid())
  taskId           String
  teamId           String
  uploadedByUserId String
  type             TaskSubmissionEvidenceType
  title            String
  url              String
  fileName         String?
  fileSize         Int?
  fileType         String?
  submittedAt      DateTime?
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt

  task       Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  team       Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  uploadedBy User @relation("TaskEvidenceUploader", fields: [uploadedByUserId], references: [id], onDelete: Cascade)

  @@index([taskId, submittedAt])
  @@index([teamId, createdAt])
  @@index([uploadedByUserId])
}

model Sprint {
