  team        Team               @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdBy   User?              @relation("SprintCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  tasks       Task[]
  evaluations SprintEvaluation[]

  @@unique([teamId, name])
  @@index([teamId, status])
  @@index([teamId, startDate, endDate])
  @@index([createdByUserId])
}

model SprintEvaluation {
  id                  String                        @id @default(cuid())
  sprintId            String
  evaluatorUserId     String
  evaluatorRole       SprintEvaluationEvaluatorRole
  status              SprintEvaluationStatus        @default(DRAFT)
  score               Int?
  feedback            String?
  planningQuality     Int?
  taskCompletion      Int?
  progressConsistency Int?
  teamCollaboration   Int?
  deadlineCommitment  Int?
  earlyEvaluation     Boolean                       @default(false)
  evaluatedAt         DateTime?
  reviewedByUserId    String?
  reviewedAt          DateTime?
  reviewComment       String?
  finalizedAt         DateTime?
  createdAt           DateTime                      @default(now())
  updatedAt           DateTime                      @updatedAt

  sprint     Sprint @relation(fields: [sprintId], references: [id], onDelete: Cascade)
  evaluator  User   @relation("SprintEvaluationEvaluator", fields: [evaluatorUserId], references: [id], onDelete: Cascade)
  reviewedBy User?  @relation("SprintEvaluationReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@unique([sprintId, evaluatorUserId, evaluatorRole])
  @@index([sprintId, status])
  @@index([evaluatorUserId])
  @@index([reviewedByUserId])
}

model WeeklyReport {
  id             String             @id @default(cuid())
  teamId         String
  submittedById  String?
  reviewedById   String?
  weekLabel      String
  periodStart    DateTime?
  periodEnd      DateTime?
